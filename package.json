{
  "name": "@crashbytes/pusher-mcp-server",
  "version": "1.0.10",
  "description": "MCP server for Pusher Channels — trigger events, query channels, and manage realtime messaging from AI agents",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "pusher-mcp-server": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pusher",
    "realtime",
    "websockets",
    "ai",
    "claude"
  ],
  "mcpName": "io.github.CrashBytes/pusher-mcp-server",
  "author": "CrashBytes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CrashBytes/pusher-mcp-server.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pusher": "^5.3.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": ">=0.28.1",
    "form-data": ">=4.0.6",
    "hono": ">=4.12.25"
  }
}
